#!/usr/bin/env bash

set -euo pipefail

cd "$(dirname "$0")/.."

echo "==> Detecting breaking changes"

if [ "$#" -ne 1 ]; then
    echo "Usage: $0 <base-commit>" >&2
    exit 2
fi

BASE_COMMIT="$1"

git cat-file -e "${BASE_COMMIT}^{commit}"

TEST_PATHS=(
	openai-java-core/src/test/kotlin/com/openai/models
	openai-java-core/src/test/kotlin/com/openai/services
)

SUPPORT_PATHS=(
	openai-java-core/src/test/kotlin/com/openai/TestServerExtension.kt
	openai-java-core/src/test/kotlin/com/openai/core/StructuredOutputsTestUtils.kt
)

# These generated tests explicitly exercise Kotlin `internal` helpers. They remain covered by the
# normal test suite, but are not consumer fixtures and must not define the public compatibility
# surface.
INTERNAL_FIXTURES=(
	openai-java-core/src/test/kotlin/com/openai/models/audio/transcriptions/TranscriptionCreateParamsTest.kt
	openai-java-core/src/test/kotlin/com/openai/models/audio/translations/TranslationCreateParamsTest.kt
	openai-java-core/src/test/kotlin/com/openai/models/chat/completions/StructuredChatCompletionCreateParamsTest.kt
	openai-java-core/src/test/kotlin/com/openai/models/containers/files/FileCreateParamsTest.kt
	openai-java-core/src/test/kotlin/com/openai/models/files/FileCreateParamsTest.kt
	openai-java-core/src/test/kotlin/com/openai/models/images/ImageCreateVariationParamsTest.kt
	openai-java-core/src/test/kotlin/com/openai/models/images/ImageEditParamsTest.kt
	openai-java-core/src/test/kotlin/com/openai/models/responses/StructuredResponseCreateParamsTest.kt
	openai-java-core/src/test/kotlin/com/openai/models/skills/SkillCreateParamsTest.kt
	openai-java-core/src/test/kotlin/com/openai/models/skills/versions/VersionCreateParamsTest.kt
	openai-java-core/src/test/kotlin/com/openai/models/uploads/parts/PartCreateParamsTest.kt
	openai-java-core/src/test/kotlin/com/openai/models/videos/VideoCreateCharacterParamsTest.kt
	openai-java-core/src/test/kotlin/com/openai/models/videos/VideoCreateParamsTest.kt
	openai-java-core/src/test/kotlin/com/openai/models/videos/VideoEditParamsTest.kt
	openai-java-core/src/test/kotlin/com/openai/models/videos/VideoExtendParamsTest.kt
	openai-java-core/src/test/kotlin/com/openai/models/videos/VideoRemixParamsTest.kt
	openai-java-core/src/test/kotlin/com/openai/services/ResponseStreamEventValidationTest.kt
)

COMPATIBILITY_ROOT="openai-java-core/build/api-compatibility-source"
rm -rf "${COMPATIBILITY_ROOT}"
mkdir -p "${COMPATIBILITY_ROOT}"

RESTORED_TEST_PATHS=0
for PATHSPEC in "${TEST_PATHS[@]}"; do
    if ! git cat-file -e "${BASE_COMMIT}:${PATHSPEC}" 2>/dev/null; then
        echo "Skipping test path absent from base commit: ${PATHSPEC}"
        continue
    fi

    # Extract the previous tests into an isolated source tree. This avoids collisions with renamed
    # current tests and keeps the working tree untouched.
    git archive "${BASE_COMMIT}" -- "${PATHSPEC}" | tar -x -C "${COMPATIBILITY_ROOT}"
    RESTORED_TEST_PATHS=$((RESTORED_TEST_PATHS + 1))
done

if [ "${RESTORED_TEST_PATHS}" -eq 0 ]; then
    echo "No baseline test paths were found in ${BASE_COMMIT}" >&2
    exit 1
fi

for PATHSPEC in "${SUPPORT_PATHS[@]}"; do
    if ! git cat-file -e "${BASE_COMMIT}:${PATHSPEC}" 2>/dev/null; then
        echo "Skipping support path absent from base commit: ${PATHSPEC}"
        continue
    fi

    git archive "${BASE_COMMIT}" -- "${PATHSPEC}" | tar -x -C "${COMPATIBILITY_ROOT}"
done

for PATHSPEC in "${INTERNAL_FIXTURES[@]}"; do
    GENERATED_PATH="${COMPATIBILITY_ROOT}/${PATHSPEC}"
    if [ -f "${GENERATED_PATH}" ]; then
        echo "Excluding internal-only compatibility fixture: ${PATHSPEC}"
        rm "${GENERATED_PATH}"
    fi
done

# Keep the public API coverage in structured-output fixtures while replacing only references to
# Kotlin-internal constructors and JsonField helpers.
replace_internal_reference() {
    local file_path="$1"
    local internal_source="$2"
    local public_source="$3"

    if [ ! -f "${file_path}" ]; then
        echo "Skipping compatibility rewrite; fixture was not restored: ${file_path}" >&2
        return
    fi

    if ! grep -Fq "${internal_source}" "${file_path}"; then
        echo "Skipping compatibility rewrite; internal reference is absent: ${file_path}" >&2
        return
    fi

    INTERNAL_SOURCE="${internal_source}" PUBLIC_SOURCE="${public_source}" \
        perl -0pi -e 's/\Q$ENV{INTERNAL_SOURCE}\E/$ENV{PUBLIC_SOURCE}/g' "${file_path}"
}

replace_internal_reference \
    "${COMPATIBILITY_ROOT}/openai-java-core/src/test/kotlin/com/openai/models/chat/completions/StructuredChatCompletionMessageTest.kt" \
    'StructuredChatCompletionMessage<X>(X::class.java, mockDelegate)' \
    'mock(StructuredChatCompletionMessage::class.java) as StructuredChatCompletionMessage<X>'
replace_internal_reference \
    "${COMPATIBILITY_ROOT}/openai-java-core/src/test/kotlin/com/openai/models/chat/completions/StructuredChatCompletionTest.kt" \
    'StructuredChatCompletion.Choice<X>(X::class.java, mockChoiceDelegate)' \
    'mock(StructuredChatCompletion.Choice::class.java) as StructuredChatCompletion.Choice<X>'
replace_internal_reference \
    "${COMPATIBILITY_ROOT}/openai-java-core/src/test/kotlin/com/openai/models/chat/completions/StructuredChatCompletionTest.kt" \
    'assertThat(output.getRequired("_choices")[0].rawChoice).isEqualTo(CHOICE)' \
    'assertThat(output).isEqualTo(input)'
replace_internal_reference \
    "${COMPATIBILITY_ROOT}/openai-java-core/src/test/kotlin/com/openai/models/chat/completions/StructuredChatCompletionTest.kt" \
    'assertThat(output.getRequired("_message").rawMessage).isEqualTo(MESSAGE)' \
    'assertThat(output).isEqualTo(input)'
replace_internal_reference \
    "${COMPATIBILITY_ROOT}/openai-java-core/src/test/kotlin/com/openai/models/responses/StructuredResponseOutputMessageTest.kt" \
    'assertThat(output.getRequired("content")[0].rawContent).isEqualTo(CONTENT)' \
    'assertThat(output).isEqualTo(input)'
replace_internal_reference \
    "${COMPATIBILITY_ROOT}/openai-java-core/src/test/kotlin/com/openai/models/responses/StructuredResponseTest.kt" \
    'assertThat(output.getRequired("_output")[0].rawOutputItem).isEqualTo(OUTPUT_ITEM)' \
    'assertThat(output).isEqualTo(input)'
replace_internal_reference \
    "${COMPATIBILITY_ROOT}/openai-java-core/src/test/kotlin/com/openai/models/responses/StructuredResponseTextConfigTest.kt" \
    'import com.openai.core.jsonSchemaFromClass
' \
    ''
replace_internal_reference \
    "${COMPATIBILITY_ROOT}/openai-java-core/src/test/kotlin/com/openai/models/responses/StructuredResponseTextConfigTest.kt" \
    'StructuredResponseTextConfig.builder<X>().inject(mockBuilderDelegate)' \
    'StructuredResponseTextConfig.builder<X>()
            .format(X::class.java)
            .verbosity(VERBOSITY)
            .verbosity(java.util.Optional.of(VERBOSITY))
            .verbosity(com.openai.core.JsonField.of(VERBOSITY))
            .additionalProperties(emptyMap())
            .putAdditionalProperty("key", com.openai.core.JsonValue.from("value"))
            .putAllAdditionalProperties(emptyMap())
            .removeAdditionalProperty("key")
            .removeAllAdditionalProperties(emptySet())'
replace_internal_reference \
    "${COMPATIBILITY_ROOT}/openai-java-core/src/test/kotlin/com/openai/models/responses/StructuredResponseTextConfigTest.kt" \
    'jsonSchemaFromClass(X::class.java)' \
    'mock(ResponseFormatTextJsonSchemaConfig::class.java)'

# Keep the compatibility compilation policy in this detector rather than in the proposed build
# file. CI also runs the detector from the base commit, so a PR cannot bypass that baseline policy
# by weakening a source set or task in openai-java-core/build.gradle.kts.
COMPATIBILITY_SOURCE_ROOT="$(pwd)/${COMPATIBILITY_ROOT}/openai-java-core/src/test/kotlin"
COMPATIBILITY_INIT_SCRIPT="$(mktemp)"
trap 'rm -f "${COMPATIBILITY_INIT_SCRIPT}"' EXIT

cat > "${COMPATIBILITY_INIT_SCRIPT}" <<'GRADLE'
import org.gradle.api.attributes.java.TargetJvmVersion

gradle.beforeProject { project ->
    if (project.path == ":openai-java-core") {
        project.pluginManager.withPlugin("org.jetbrains.kotlin.jvm") {
            def sourceSets = project.extensions.getByName("sourceSets")
            def compatibility = sourceSets.create("externalApiCompatibility")
            compatibility.kotlin.srcDir(System.getenv("COMPATIBILITY_SOURCE_ROOT"))
            compatibility.compileClasspath += sourceSets.getByName("main").output

            project.configurations
                .getByName(compatibility.implementationConfigurationName)
                .extendsFrom(project.configurations.getByName("testImplementation"))
            project.configurations
                .getByName(compatibility.compileClasspathConfigurationName)
                .attributes
                .attribute(TargetJvmVersion.TARGET_JVM_VERSION_ATTRIBUTE, 17)
        }
    }
}
GRADLE

COMPATIBILITY_SOURCE_ROOT="${COMPATIBILITY_SOURCE_ROOT}" \
    ./scripts/gradle \
    --init-script "${COMPATIBILITY_INIT_SCRIPT}" \
    :openai-java-core:compileExternalApiCompatibilityKotlin \
    --no-build-cache
